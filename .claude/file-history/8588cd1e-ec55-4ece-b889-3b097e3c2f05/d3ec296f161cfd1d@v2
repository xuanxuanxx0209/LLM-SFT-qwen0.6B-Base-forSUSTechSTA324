#!/usr/bin/env python3
"""Launch OpenRLHF SFT training for Qwen3-0.6B-Base math fine-tuning."""

import subprocess
import sys
from pathlib import Path


def main():
    model_dir = Path(__file__).parent.resolve()
    dataset_path = "/home/ubuntu/jgy-dataset/final_cleaned_high_quality.jsonl"
    output_path = "/home/ubuntu/models/Qwen3-0.6B-Base-SFT-Math"
    template_path = model_dir / "qwen3_math_sft_chat_template.jinja"
    tb_log_dir = Path(output_path) / "tensorboard_logs"

    if not template_path.exists():
        print(f"ERROR: Chat template not found: {template_path}", file=sys.stderr)
        sys.exit(1)

    if not Path(dataset_path).exists():
        print(f"ERROR: Dataset not found: {dataset_path}", file=sys.stderr)
        sys.exit(1)

    chat_template = template_path.read_text(encoding="utf-8")

    cmd = [
        sys.executable,
        "-m",
        "openrlhf.cli.train_sft",
        "--pretrain",
        str(model_dir),
        "--dataset",
        dataset_path,
        "--save_path",
        output_path,
        "--max_len",
        "4096",
        "--micro_train_batch_size",
        "4",
        "--train_batch_size",
        "16",
        "--learning_rate",
        "1e-6",
        "--max_epochs",
        "3",
        "--param_dtype",
        "bf16",
        "--logging_steps",
        "5",
        "--save_steps",
        "-1",
        "--max_ckpt_num",
        "0",
        "--gradient_checkpointing",
        "--zero_stage",
        "2",
        "--apply_chat_template",
        "--input_key",
        "messages",
        "--tokenizer_chat_template",
        chat_template,
        "--use_tensorboard",
        str(tb_log_dir),
        "--wandb_run_name",
        "qwen3-0.6b-sft-math",
        "--attn_implementation",
        "eager",
    ]

    print("Running command:")
    print(" ".join(cmd[:10]) + " ...")
    print(f"Chat template length: {len(chat_template)} characters")
    print("")

    result = subprocess.run(cmd)
    sys.exit(result.returncode)


if __name__ == "__main__":
    main()
