#!/usr/bin/env python3
"""Convert raw jsonl dataset to OpenRLHF SFT messages format.

Input format (per line):
  {"question": str, "solution": str, "answer": "\\boxed{...}", "id": str}

Output format (per line):
  {"messages": [
      {"role": "user", "content": question},
      {"role": "assistant", "content": "<think>solution</think>answer"}
  ]}

The chat template at templates/qwen3_06b_base_eot_chat_template.jinja extracts
the <think>...</think> block as reasoning and treats the trailing text as the
final answer, so the produced content matches that template.
"""

from __future__ import annotations

import argparse
import json
from pathlib import Path


def convert(src: Path, dst: Path) -> int:
    count = 0
    with src.open("r", encoding="utf-8") as fin, dst.open("w", encoding="utf-8") as fout:
        for line in fin:
            line = line.strip()
            if not line:
                continue
            obj = json.loads(line)
            question = (obj.get("question") or "").strip()
            solution = (obj.get("solution") or "").strip()
            answer = (obj.get("answer") or "").strip()
            if not question or not answer:
                continue
            assistant_content = f"<think>{solution}</think>{answer}"
            record = {
                "messages": [
                    {"role": "user", "content": question},
                    {"role": "assistant", "content": assistant_content},
                ]
            }
            fout.write(json.dumps(record, ensure_ascii=False) + "\n")
            count += 1
    return count


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument(
        "--src",
        default="/home/ubuntu/jgy-dataset/data large none.jsonl",
    )
    parser.add_argument(
        "--dst",
        default="/home/ubuntu/sft_qwen3_run/sft_train.jsonl",
    )
    args = parser.parse_args()

    src = Path(args.src).resolve()
    dst = Path(args.dst).resolve()
    dst.parent.mkdir(parents=True, exist_ok=True)

    n = convert(src, dst)
    print(f"Converted {n} records from {src} to {dst}")


if __name__ == "__main__":
    main()
